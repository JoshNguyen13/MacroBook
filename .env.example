# Supabase project settings (Project Settings -> API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# USDA FoodData Central (free key at https://fdc.nal.usda.gov/api-key-signup.html)
USDA_API_KEY=your-usda-key

# Spoonacular is called from a Supabase Edge Function, not from the client.
# Set SPOONACULAR_API_KEY as an Edge Function secret instead:
#   supabase secrets set SPOONACULAR_API_KEY=your-key
